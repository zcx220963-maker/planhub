# ══════════════════════════════════════════════════════════════
# PlanHub — 环境变量模板（git 不会提交此文件的真实值）
#
# 使用方法：
#   1. 复制本文件为 .env（Windows PowerShell）
#      cp .env.example .env
#   2. 根据下面的说明填入你的真实值
#   3. 启动项目
#
# 读取优先级（从高到低）：
#   系统环境变量 > .env 文件 > application.yml / config.py 默认值
# ══════════════════════════════════════════════════════════════

# ── Java 后端 ───────────────────────────────────────────────
# 数据库连接信息
DB_URL=jdbc:mysql://localhost:3306/planhub?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# JWT 密钥（生产环境请换成 64 字节以上的随机字符串）
JWT_SECRET=your-jwt-secret-key-at-least-64-characters-long-change-it
JWT_ACCESS_TOKEN_EXPIRATION=3600000
JWT_REFRESH_TOKEN_EXPIRATION=86400000

# AI 服务地址与内部密钥（Java 后端通过此地址调用 Python AI 服务）
AI_SERVICE_URL=http://127.0.0.1:8000
AI_INTERNAL_SECRET=planhub-internal-secret-change-in-production-please
AI_INTERNAL_SECRET_HEADER=X-Internal-Api-Secret
AI_CONNECT_TIMEOUT=5000
AI_READ_TIMEOUT=300000

# ── Python AI 服务 ─────────────────────────────────────────
# 服务监听（127.0.0.1 仅限本机访问，防止外部直接调用）
AI_HOST=127.0.0.1
AI_PORT=8000

# LLM 提供者：ollama 或 dashscope（默认本地 ollama）
USE_DASHSCOPE=false

# Ollama 本地模型（推荐使用 qwen3:1.7b + nomic-embed-text 嵌入模型）
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:1.7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# 阿里云百炼/通义千问（可选，把 USE_DASHSCOPE 设为 true 才生效）
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v2

# Redis（对话历史存储，未安装可设 USE_REDIS=false）
USE_REDIS=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# PlanHub 后端 API 地址（智能助手调用 Java 后端用）
PLANHUB_API_BASE=http://localhost:8080/api
PLANHUB_USERNAME=admin
PLANHUB_PASSWORD=

# ── 外部 API（可选，不配置不影响核心功能）──────────
# 天气：https://openweathermap.org（免费）
OPENWEATHERMAP_API_KEY=

# 新闻：https://newsapi.org（免费）
NEWSAPI_API_KEY=

# 汇率：https://www.exchangerate-api.com（免费，无需 key，latest 即可）
EXCHANGERATE_API_KEY=latest

# ── Nacos（可选，没装请忽略）───────────────────────
# 如果你部署了 Nacos 作为配置中心，把下面两个改成 true
NACOS_CONFIG_ENABLED=false
NACOS_DISCOVERY_ENABLED=false
NACOS_SERVER_ADDR=127.0.0.1:8848
NACOS_NAMESPACE=public
NACOS_GROUP=DEFAULT_GROUP
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# ── 测试模式 ──────────────────────────────────────────
TEST_MODE=false
