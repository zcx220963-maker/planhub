# ══════════════════════════════════════════════════════════════
# PlanHub Python AI 服务 — 环境变量模板
#
# 推荐做法：
#   1) 在项目根目录 (planhub2.0/) 创建 .env 并配置
#   2) 或复制根目录的 .env.example 为 .env
#
# 此文件被 pydantic_settings 自动读取
# ══════════════════════════════════════════════════════════════

# LLM 提供者：ollama 或 dashscope
USE_DASHSCOPE=false

# 本地 Ollama（默认使用）
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:1.7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# 阿里云百炼（可选，把 USE_DASHSCOPE 改成 true 才生效）
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v2

# 服务监听（127.0.0.1 防止外部直接调用）
AI_HOST=127.0.0.1
AI_PORT=8000

# 向量库 & PlanHub 后端
CHROMA_DB_PATH=./chroma_db
PLANHUB_API_BASE=http://localhost:8080/api
PLANHUB_USERNAME=admin
PLANHUB_PASSWORD=

# Redis（对话历史，未安装设 USE_REDIS=false）
USE_REDIS=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Java <-> Python 内部鉴权密钥（生产务必修改）
INTERNAL_API_SECRET=planhub-internal-secret-change-in-production-please
INTERNAL_SECRET_HEADER=X-Internal-Api-Secret

# 外部 API（可选）
OPENWEATHERMAP_API_KEY=
NEWSAPI_API_KEY=
EXCHANGERATE_API_KEY=latest

# ─── Langfuse 配置（可观测性）─────────────────────────────────
# 自托管 Langfuse: http://localhost:3000
# 云版 Langfuse: https://cloud.langfuse.com
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_ENABLED=false  # 设置为 true 启用

# ─── 高德地图 API（可选）──────────────────────────────────────
AMAP_API_KEY=

# ─── Tavily 搜索 API（可选）────────────────────────────────────
TAVILY_API_KEY=

# 测试模式
TEST_MODE=false
